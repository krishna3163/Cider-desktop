<script type="text/x-template" id="drm-diagnostics-modal">
    <div class="modal-fullscreen addtoplaylist-panel" @click.self="close()" @contextmenu.self="close()">
        <div class="modal-window" style="max-width: 550px; width: 90%; background: #1e1e1e; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; overflow: hidden; box-shadow: 0 12px 24px rgba(0, 0, 0, 0.5);">
            <div class="modal-header" style="border-bottom: 1px solid rgba(255, 255, 255, 0.08); padding: 16px 20px;">
                <div class="modal-title" style="font-size: 1.15rem; font-weight: bold; color: #fff;">Playback & DRM Diagnostics</div>
                <button class="close-btn" @click="close()" :aria-label="app.getLz('action.close')"></button>
            </div>
            
            <div class="modal-content scrollbody" style="padding: 16px; max-height: 65vh; overflow-y: auto;">
                
                <!-- Live Diagnostics Status Card -->
                <div style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); padding: 12px; border-radius: 8px; margin-bottom: 16px; font-size: 0.88rem;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                        <span style="color: rgba(255,255,255,0.6)">Network Connection:</span>
                        <strong :style="{color: status.online ? '#4caf50' : '#f44336'}">{{ status.online ? 'Online' : 'Offline' }}</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                        <span style="color: rgba(255,255,255,0.6)">Apple Music Session:</span>
                        <strong :style="{color: status.authorized ? '#4caf50' : '#f44336'}">{{ status.authorized ? 'Active (Subscribed)' : 'No Active Session' }}</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: rgba(255,255,255,0.6)">Current Storefront:</span>
                        <strong style="color: var(--keyColor)">{{ status.country }} ({{ status.storefront.toUpperCase() }})</strong>
                    </div>
                </div>

                <div style="margin-bottom: 12px; font-size: 0.95rem; font-weight: bold; color: rgba(255, 255, 255, 0.8);">
                    Please select the playback issue to see the solution:
                </div>

                <!-- Selectable reasons using native playlist-item style -->
                <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px;">
                    <button v-for="(reason, index) in reasons" 
                            :key="index"
                            class="playlist-item" 
                            @click="selectedReasonIndex = index"
                            :style="selectedReasonIndex === index ? { borderLeft: '4px solid var(--keyColor)', background: 'rgba(255,255,255,0.08)' } : {}"
                            style="width: 100%; text-align: left; display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border: none; border-radius: 6px; cursor: pointer; color: #fff;">
                        <div style="display: flex; align-items: center;">
                            <div class="icon" style="margin-right: 12px; display: flex; align-items: center; justify-content: center; width: 24px; height: 24px;">
                                <div :class="['codicon', reason.icon]" style="font-size: 1.2rem; color: var(--keyColor);"></div>
                            </div>
                            <div class="name" style="font-size: 0.95rem;">{{ reason.title }}</div>
                        </div>
                        <div class="codicon codicon-chevron-right" style="color: rgba(255, 255, 255, 0.4);" v-if="selectedReasonIndex !== index"></div>
                    </button>
                </div>

                <!-- Selected Reason Detailed Info Card -->
                <div v-if="selectedReasonIndex !== null" 
                     style="background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 8px; padding: 14px; transition: all 0.2s;">
                    <div style="font-weight: bold; color: #fff; margin-bottom: 8px; display: flex; align-items: center; font-size: 0.95rem;">
                        <div :class="['codicon', reasons[selectedReasonIndex].icon]" style="margin-right: 8px; color: var(--keyColor)"></div>
                        {{ reasons[selectedReasonIndex].title }}
                    </div>
                    <p style="font-size: 0.88rem; color: rgba(255, 255, 255, 0.75); line-height: 1.5; margin-bottom: 10px;">
                        {{ reasons[selectedReasonIndex].desc }}
                    </p>
                    <div style="background: rgba(252, 60, 68, 0.1); border-left: 3px solid var(--keyColor); padding: 8px 12px; border-radius: 4px; color: #ff8a9c; font-size: 0.88rem; line-height: 1.4;">
                        <strong>💡 Solution:</strong> {{ reasons[selectedReasonIndex].fix }}
                    </div>
                </div>

            </div>
            
            <div style="display: flex; justify-content: flex-end; gap: 10px; padding: 12px 20px; border-top: 1px solid rgba(255, 255, 255, 0.08); background: rgba(0, 0, 0, 0.1);">
                <button class="md-btn" @click="reauthorize()" style="background: transparent; border: 1px solid rgba(255,255,255,0.2); color: #fff; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-size: 0.88rem;">
                    Re-login Apple Music
                </button>
                <button class="md-btn" @click="close()" style="background: var(--keyColor); color: #fff; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-size: 0.88rem; font-weight: bold;">
                    Close
                </button>
            </div>
        </div>
    </div>
</script>

<script>
  Vue.component('drm-diagnostics-modal', {
    template: '#drm-diagnostics-modal',
    data: function() {
      return {
        app: this.$root,
        selectedReasonIndex: 0,
        status: {
          online: navigator.onLine,
          authorized: false,
          country: "India", // Default to India
          storefront: "in"  // Default to India storefront
        },
        reasons: [
          {
            title: "Track is DRM-Protected",
            icon: "codicon-lock",
            desc: "Some catalog tracks require GPU hardware decryption validation (FairPlay/Widevine). Software rendering (SwiftShader) is unsupported and blocks DRM streams, playing only 30-second previews.",
            fix: "Keep Hardware Acceleration enabled in Cider visual settings. We have forced this enabled on Windows to protect DRM playback."
          },
          {
            title: "Apple Music Subscription Inactive",
            icon: "codicon-person-filled",
            desc: "An active subscription is strictly required to stream full songs. If your account is in preview mode, or has lapsed, Apple Music restricts playback to 30-second previews.",
            fix: "Verify your subscription is active at music.apple.com or try re-logging in using the button below."
          },
          {
            title: "Storefront Region Mismatch",
            icon: "codicon-globe",
            desc: "Tracks can be restricted in certain countries, or your current Apple Music storefront region doesn't match the track's country code in the playlist.",
            fix: "Change your storefront region in your Apple Music account settings or use tracks available in your local storefront."
          },
          {
            title: "Downloader Processing Failures",
            icon: "codicon-cloud-download",
            desc: "Third party track/album downloaders sometimes strip the DRM-headers or save corrupted cache files, triggering verification errors on player side.",
            fix: "Try clearing your Cider cache under settings or re-adding the track to your library."
          },
          {
            title: "Outdated Client / MusicKit Server Changes",
            icon: "codicon-git-compare",
            desc: "Apple occasionally changes security headers on their DRM key servers, causing older client wrappers to fail authentication temporarily.",
            fix: "Always update Cider to the latest stable build to stay compatible with Apple Music's backend changes."
          }
        ]
      }
    },
    mounted() {
      this.runStatusCheck();
    },
    methods: {
      close() {
        this.$root.modals.drmDiagnostics = false;
      },
      async reauthorize() {
        this.close();
        this.$root.appMode = "oobe";
      },
      async runStatusCheck() {
        // Auth check
        try {
          this.status.authorized = MusicKit.getInstance().isAuthorized;
          this.status.storefront = MusicKit.getInstance().storefrontId || "in";
        } catch(e){}

        // Country/IP auto detection
        try {
          const res = await fetch("https://ipapi.co/json/");
          const data = await res.json();
          if (data && data.country_name) {
            this.status.country = data.country_name;
            this.status.storefront = data.country_code ? data.country_code.toLowerCase() : "in";
            
            // Automatically expand Region/Storefront reason if IP region doesn't match storefront
            if (this.status.storefront && data.country_code && this.status.storefront.toUpperCase() !== data.country_code.toUpperCase()) {
              this.selectedReasonIndex = 2; // Auto-select Storefront Region Mismatch
            }
          }
        } catch(e) {
          // Fallback to defaults
          this.status.country = "India";
          this.status.storefront = "in";
        }
      }
    }
  });
</script>
